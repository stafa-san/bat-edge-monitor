rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Offline WAV uploads ───────────────────────────────────
    // Path pattern: uploads/<uuid>.wav
    //
    // Anonymous writes are allowed so the analysis can work from any
    // browser without forcing users to sign in. The worker on the Pi
    // reads via the Admin SDK (bypasses these rules), so we keep reads
    // closed for the public. Constraints enforced:
    //   * filename must be a UUIDv4 with .wav extension
    //   * size ≤ 100 MB
    //   * content type audio/wav
    //
    // Buckets also have a GCS lifecycle rule (see firebase/storage-lifecycle.json)
    // that deletes uploads/* objects after 7 days.
    match /uploads/{filename} {
      allow read: if false;
      allow write: if
        filename.matches('[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\\.wav')
        && request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType == 'audio/wav';
    }

    // Spectrogram PNGs rendered by the Cloud Function. Publicly readable
    // so any committee member with the dashboard URL can load them.
    // Writes are Admin-SDK only.
    match /spectrograms/{filename} {
      allow read: if true;
      allow write: if false;
    }

    // Time-expanded audio WAVs rendered by the Cloud Function (10×
    // slowdown so ultrasonic calls become audible for playback).
    // Publicly readable; Admin-SDK only writes.
    match /audio/{filename} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
