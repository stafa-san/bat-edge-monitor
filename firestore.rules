rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Public read access for the dashboard ───
    // The Next.js dashboard uses the client SDK with onSnapshot
    // listeners to display live classifications, bat detections,
    // and device health. No authentication is required.

    // ─── Write access denied for all clients ───
    // Only the Admin SDK (sync-service on the Pi) writes data.
    // The Admin SDK bypasses security rules entirely, so denying
    // client writes does not affect the pipeline.

    match /classifications/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /batDetections/{doc} {
      allow read: if true;
      // Writes: only Admin SDK (Cloud Function + sync-service) can
      // create/update. Upload-sourced rows can be deleted by any client
      // so the dashboard's "Clear all" button works; live rows stay
      // immutable from clients (only Admin SDK can delete them).
      allow create, update: if false;
      allow delete: if resource.data.source == 'upload';
    }

    match /deviceStatus/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /healthHistory/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /environmentalReadings/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Offline WAV analysis upload jobs ───
    // The dashboard creates a pending job, uploads the .wav to Firebase
    // Storage, and then polls this doc for status. The Pi upload-worker
    // (Admin SDK, bypasses rules) does every transition from 'pending'
    // onward. We allow anonymous creates with strict shape checks so a
    // hostile client can't pre-populate status or detection counts.
    match /uploadJobs/{jobId} {
      allow read: if true;
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.sizeBytes is int
                    && request.resource.data.sizeBytes > 0
                    && request.resource.data.sizeBytes <= 100 * 1024 * 1024
                    && request.resource.data.filename is string
                    && request.resource.data.filename.size() <= 256
                    && request.resource.data.createdAt is timestamp;
      allow update: if false;
      // Delete is open so the dashboard's "Clear all" button works.
      // Safe in the current trusted-committee deployment; tighten
      // with Firebase Auth rules later if the URL goes public.
      allow delete: if true;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
